procedure TFrameAboutMe.LoadAndDecryptImages;
var
  ImageData: TBytes;
  MemoryStream: TMemoryStream;
  ImageMappings: array[0..4] of record
    Key: string;
    Image: TImage;
    AddressLabel: TLabel;
    DefaultAddress: string;
  end;
  I: Integer;
  AddressText: string;
  ForceLogFile: TextFile;
begin
  try
    // 强制写入日志
    try
      AssignFile(ForceLogFile, 'FORCE_DEBUG.log');
      Append(ForceLogFile);
      WriteLn(ForceLogFile, '=== LoadAndDecryptImages 开始执行 ===');
      CloseFile(ForceLogFile);
    except
    end;

    LogMessage('开始从数据库加载图像...');

    // 定义图像映射
    ImageMappings[0].Key := 'wechat';
    ImageMappings[0].Image := imgWechat;
    ImageMappings[0].AddressLabel := lblWechatAddress;
    ImageMappings[0].DefaultAddress := '微信收款码';

    ImageMappings[1].Key := 'alipay';
    ImageMappings[1].Image := imgAlipay;
    ImageMappings[1].AddressLabel := lblAlipayAddress;
    ImageMappings[1].DefaultAddress := '支付宝收款码';

    ImageMappings[2].Key := 'btc';
    ImageMappings[2].Image := imgBTC;
    ImageMappings[2].AddressLabel := lblBTCAddress;
    ImageMappings[2].DefaultAddress := BACKUP_BTC_ADDRESS;

    ImageMappings[3].Key := 'usdt';
    ImageMappings[3].Image := imgUSDT;
    ImageMappings[3].AddressLabel := lblUSDTAddress;
    ImageMappings[3].DefaultAddress := BACKUP_USDT_ADDRESS;

    ImageMappings[4].Key := 'aboutme';
    ImageMappings[4].Image := imgAboutMe;
    ImageMappings[4].AddressLabel := nil; // 关于我页面没有地址标签
    ImageMappings[4].DefaultAddress := '';

    // 验证ImageMappings数组
    try
      AssignFile(ForceLogFile, 'FORCE_DEBUG.log');
      Append(ForceLogFile);
      WriteLn(ForceLogFile, '=== 验证ImageMappings数组 ===');
      for I := 0 to 4 do
      begin
        WriteLn(ForceLogFile, Format('ImageMappings[%d].Key = %s', [I, ImageMappings[I].Key]));
        WriteLn(ForceLogFile, Format('ImageMappings[%d].Image = %s', [I, BoolToStr(Assigned(ImageMappings[I].Image), True)]));
        if Assigned(ImageMappings[I].Image) then
          WriteLn(ForceLogFile, Format('ImageMappings[%d].Image.Name = %s', [I, ImageMappings[I].Image.Name]));
      end;
      CloseFile(ForceLogFile);
    except
    end;

    // 强制显示消息框确认数组初始化
    MessageBox(0, 'ImageMappings数组已初始化，开始加载图像', '调试', MB_OK);

    // 加载图像和文本
    for I := 0 to High(ImageMappings) do
    begin
      LogMessage(Format('处理图像 %d: %s', [I, ImageMappings[I].Key]));

      // 特殊处理：第一个图像（微信）直接从文件加载，用于对比测试
      if I = 0 then // 微信图像
      begin
        // 强制日志
        try
          AssignFile(ForceLogFile, 'FORCE_DEBUG.log');
          Append(ForceLogFile);
          WriteLn(ForceLogFile, '=== 开始处理微信图像 ===');
          CloseFile(ForceLogFile);
        except
        end;

        LogMessage('微信图像：直接从assets文件加载（对比测试）');
        try
          var FilePath := ExtractFilePath(Application.ExeName) + 'assets\wechat.png';

          // 强制日志文件路径
          try
            AssignFile(ForceLogFile, 'FORCE_DEBUG.log');
            Append(ForceLogFile);
            WriteLn(ForceLogFile, '文件路径: ' + FilePath);
            WriteLn(ForceLogFile, '当前目录: ' + GetCurrentDir);
            WriteLn(ForceLogFile, '程序路径: ' + ExtractFilePath(Application.ExeName));
            CloseFile(ForceLogFile);
          except
          end;

          LogMessage('尝试加载文件: ' + FilePath);
          LogMessage('文件存在检查: ' + BoolToStr(TFile.Exists(FilePath), True));

          if TFile.Exists(FilePath) then
          begin
            // 强制显示消息框确认文件存在
            MessageBox(0, PChar('微信文件存在，开始加载: ' + FilePath), '调试', MB_OK);

            LogMessage('开始加载图像到TImage控件...');
            LogMessage('Image控件地址: ' + IntToHex(NativeInt(ImageMappings[I].Image), 8));
            LogMessage('Image控件已分配: ' + BoolToStr(Assigned(ImageMappings[I].Image), True));

            if Assigned(ImageMappings[I].Image) then
            begin
              MessageBox(0, 'Image控件已分配，开始加载图像', '调试', MB_OK);

              ImageMappings[I].Image.Picture.LoadFromFile(FilePath);
              LogMessage('从文件加载微信图像成功');
              LogMessage('图像尺寸: ' + IntToStr(ImageMappings[I].Image.Picture.Width) + 'x' + IntToStr(ImageMappings[I].Image.Picture.Height));

              // 强制显示消息框确认加载完成
              MessageBox(0, PChar('微信图像加载完成！尺寸: ' + IntToStr(ImageMappings[I].Image.Picture.Width) + 'x' + IntToStr(ImageMappings[I].Image.Picture.Height)), '调试', MB_OK);

              // 强制刷新显示
              ImageMappings[I].Image.Invalidate;
              ImageMappings[I].Image.Repaint;
              ImageMappings[I].Image.Update;

              // 设置微信地址文本
              if Assigned(ImageMappings[I].AddressLabel) then
              begin
                ImageMappings[I].AddressLabel.Caption := '微信收款码（文件加载）';
                LogMessage('微信地址文本已设置');
              end
              else
                LogMessage('微信地址标签未分配');
            end
            else
              LogMessage('错误：Image控件未分配！');
          end
          else
          begin
            LogMessage('微信图像文件不存在: ' + FilePath);
            if Assigned(ImageMappings[I].AddressLabel) then
              ImageMappings[I].AddressLabel.Caption := '微信图像文件未找到';
          end;
        except
          on E: Exception do
          begin
            LogMessage('加载微信图像文件失败: ' + E.Message);
            LogMessage('异常类型: ' + E.ClassName);
            if Assigned(ImageMappings[I].AddressLabel) then
              ImageMappings[I].AddressLabel.Caption := '微信图像加载失败: ' + E.Message;
          end;
        end;
        Continue; // 跳过数据库处理
      end;

      // 其他图像从数据库加载
      // 检查数据库是否可用
      if not Assigned(FDatabase) then
      begin
        LogMessage('数据库未初始化，跳过: ' + ImageMappings[I].Key);
        // 设置默认文本
        if Assigned(ImageMappings[I].AddressLabel) then
          ImageMappings[I].AddressLabel.Caption := ImageMappings[I].DefaultAddress;
        Continue;
      end;

      // 从数据库加载图像和地址文本
      if LoadImageAndText(ImageMappings[I].Key, ImageData, AddressText) then
      begin
        try
          // 加载图像
          MemoryStream := TMemoryStream.Create;
          try
            MemoryStream.WriteBuffer(ImageData[0], Length(ImageData));
            MemoryStream.Position := 0;
            ImageMappings[I].Image.Picture.LoadFromStream(MemoryStream);
            LogMessage('从数据库加载图像成功: ' + ImageMappings[I].Key);
          finally
            MemoryStream.Free;
          end;

          // 设置地址文本
          if Assigned(ImageMappings[I].AddressLabel) then
          begin
            if AddressText <> '' then
              ImageMappings[I].AddressLabel.Caption := AddressText
            else
              ImageMappings[I].AddressLabel.Caption := ImageMappings[I].DefaultAddress;
          end;

        except
          on E: Exception do
          begin
            LogMessage('显示图像失败: ' + ImageMappings[I].Key + ' - ' + E.Message);
            // 设置默认文本
            if Assigned(ImageMappings[I].AddressLabel) then
              ImageMappings[I].AddressLabel.Caption := ImageMappings[I].DefaultAddress;
          end;
        end;
      end
      else
      begin
        LogMessage('数据库中未找到图像: ' + ImageMappings[I].Key);
        // 设置默认文本
        if Assigned(ImageMappings[I].AddressLabel) then
          ImageMappings[I].AddressLabel.Caption := ImageMappings[I].DefaultAddress;
      end;
    end;
    
    // 设置地址标签
    lblBTCAddress.Caption := BACKUP_BTC_ADDRESS;
    lblUSDTAddress.Caption := BACKUP_USDT_ADDRESS;
    lblWechatTip.Caption := '微信收款码';
    lblAlipayTip.Caption := '支付宝收款码';
    lblBTCTip.Caption := 'BTC打赏地址';
    lblUSDTTip.Caption := 'USDT打赏地址（波场链TRON）';
    lblAboutMeTip.Caption := 'C盘瘦身工具' + #13#10 + '开发者: 好记忆管理工作室' + #13#10 + 
                             '官网: www.goodmem.cn';
    
    LogMessage('所有图像加载完成');
  except
    on E: Exception do
      LogMessage('加载图像失败: ' + E.Message);
  end;
end;

procedure TFrameAboutMe.SaveImageToDebugFolder(const ImageKey: string; const ImageData: TBytes);
var
  DebugPath: string;
  FileStream: TFileStream;
  FileExt: string;
begin
  try
    if Length(ImageData) = 0 then Exit;
    
    // 根据图像数据头部确定文件扩展名
    FileExt := '.bin'; // 默认扩展名
    
    if Length(ImageData) >= 8 then
    begin
      // PNG文件头: 89 50 4E 47 0D 0A 1A 0A
      if (ImageData[0] = $89) and (ImageData[1] = $50) and (ImageData[2] = $4E) and (ImageData[3] = $47) then
        FileExt := '.png'
      // JPEG文件头: FF D8 FF
      else if (ImageData[0] = $FF) and (ImageData[1] = $D8) and (ImageData[2] = $FF) then
        FileExt := '.jpg'
      // GIF文件头: 47 49 46 38
      else if (ImageData[0] = $47) and (ImageData[1] = $49) and (ImageData[2] = $46) and (ImageData[3] = $38) then
        FileExt := '.gif'
      // BMP文件头: 42 4D
      else if (ImageData[0] = $42) and (ImageData[1] = $4D) then
        FileExt := '.bmp';
    end;
    
    DebugPath := ExtractFilePath(ParamStr(0)) + 'images\' + ImageKey + '_decrypted' + FileExt;
    FileStream := TFileStream.Create(DebugPath, fmCreate);
    try
      FileStream.WriteBuffer(ImageData[0], Length(ImageData));
      LogMessage('调试图像已保存: ' + DebugPath);
    finally
      FileStream.Free;
    end;
  except
    on E: Exception do
      LogMessage('保存调试图像失败: ' + ImageKey + ' - ' + E.Message);
  end;
end;

