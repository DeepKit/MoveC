constructor TFrameAboutMe.Create(AOwner: TComponent);
var
  ForceLogFile: TextFile;
begin
  inherited Create(AOwner);

  // 强制显示消息框确认Create被调用
  try
    MessageBox(0, 'FrameAboutMe.Create被调用了！', 'Frame调试', MB_OK);
  except
  end;

  // 强制写入日志到固定文件，不依赖LogMessage
  try
    AssignFile(ForceLogFile, 'FRAME_CREATE_DEBUG.log');
    Rewrite(ForceLogFile);
    WriteLn(ForceLogFile, '=== FrameAboutMe.Create 开始执行 ===');
    WriteLn(ForceLogFile, '时间: ' + DateTimeToStr(Now));
    CloseFile(ForceLogFile);
  except
    // 如果连这个都失败，说明有严重问题
  end;

  // 初始化数据库
  try
    AssignFile(ForceLogFile, 'FRAME_CREATE_DEBUG.log');
    Append(ForceLogFile);
    WriteLn(ForceLogFile, '开始初始化数据库...');
    CloseFile(ForceLogFile);
  except
  end;

  InitializeDatabase;

  // 强制显示消息框确认数据库初始化完成
  try
    MessageBox(0, '数据库初始化完成，即将加载图像', 'Frame调试', MB_OK);
  except
  end;

  // 强制调用图像加载
  try
    AssignFile(ForceLogFile, 'FRAME_CREATE_DEBUG.log');
    Append(ForceLogFile);
    WriteLn(ForceLogFile, '强制调用LoadAndDecryptImages...');
    CloseFile(ForceLogFile);

    LoadAndDecryptImages;

    AssignFile(ForceLogFile, 'FRAME_CREATE_DEBUG.log');
    Append(ForceLogFile);
    WriteLn(ForceLogFile, 'LoadAndDecryptImages调用完成');
    CloseFile(ForceLogFile);
  except
    on E: Exception do
    begin
      MessageBox(0, PChar('LoadAndDecryptImages失败: ' + E.Message), '错误', MB_OK);
      try
        AssignFile(ForceLogFile, 'FRAME_CREATE_DEBUG.log');
        Append(ForceLogFile);
        WriteLn(ForceLogFile, 'LoadAndDecryptImages异常: ' + E.Message);
        CloseFile(ForceLogFile);
      except
      end;
    end;
  end;

  // 设置PageControl的OnDrawTab事件
  pcAboutMe.OwnerDraw := True;
  pcAboutMe.OnDrawTab := pcAboutMeDrawTab;

  // 更新机器码显示
  UpdateMachineCodeDisplay;

  // 创建和清空images目录
  CreateImagesDirectory;
  ClearImagesDirectory;

  // 从数据库加载并解密图像
  LoadAndDecryptImages;

  LogMessage('FrameAboutMe: 初始化完成');
end;

destructor TFrameAboutMe.Destroy;
begin
  if Assigned(FDatabase) then
    FDatabase.Free;
  inherited;
end;

procedure TFrameAboutMe.InitializeDatabase;
var
  DatabasePath: string;
begin
  try
    LogMessage('FrameAboutMe: 开始初始化数据库');

    // 使用项目根目录下的MoveC.db
    DatabasePath := TImageDatabase.GetProjectDatabasePath;
    LogMessage('数据库路径: ' + DatabasePath);

    try
      // 创建数据库连接
      if Assigned(FDatabase) then
        FDatabase.Free;

      FDatabase := TImageDatabase.Create(DatabasePath);
      if FDatabase.Connect then
      begin
        LogMessage('数据库连接成功: ' + DatabasePath);
      end
      else
      begin
        LogMessage('数据库连接失败: ' + DatabasePath);
        if Assigned(FDatabase) then
        begin
          FDatabase.Free;
          FDatabase := nil;
        end;
      end;
    except
      on E: Exception do
      begin
        LogMessage('数据库连接异常: ' + DatabasePath + ' - ' + E.Message);
        if Assigned(FDatabase) then
        begin
          FDatabase.Free;
          FDatabase := nil;
        end;
      end;
    end;

    LogMessage('FrameAboutMe: 数据库初始化完成');
  except
    on E: Exception do
    begin
      LogMessage('数据库初始化失败: ' + E.Message);
      if Assigned(FDatabase) then
      begin
        FDatabase.Free;
        FDatabase := nil;
      end;
    end;
  end;
end;

procedure TFrameAboutMe.CreateImagesDirectory;
var
  ImagesPath: string;
begin
  ImagesPath := ExtractFilePath(ParamStr(0)) + 'images';
  if not TDirectory.Exists(ImagesPath) then
  begin
    TDirectory.CreateDirectory(ImagesPath);
    LogMessage('创建images目录: ' + ImagesPath);
  end;
end;

procedure TFrameAboutMe.ClearImagesDirectory;
var
  ImagesPath: string;
  Files: TArray<string>;
  FileName: string;
begin
  ImagesPath := ExtractFilePath(ParamStr(0)) + 'images';
  if TDirectory.Exists(ImagesPath) then
  begin
    Files := TDirectory.GetFiles(ImagesPath);
    for FileName in Files do
    begin
      TFile.Delete(FileName);
    end;
    LogMessage('清空images目录');
  end;
end;



function TFrameAboutMe.LoadImageFromDatabase(const ImageKey: string): TBytes;
begin
  SetLength(Result, 0);

  try
    // 检查数据库是否可用
    if not Assigned(FDatabase) then
    begin
      LogMessage('数据库未初始化，跳过数据库加载: ' + ImageKey);
      Exit;
    end;

    // 直接从新的数据库类加载解密后的数据
    if FDatabase.LoadImageData(ImageKey, Result) then
    begin
      LogMessage(Format('图像已从数据库加载: %s (%d 字节)', [ImageKey, Length(Result)]));
    end
    else
    begin
      LogMessage('数据库中未找到图像: ' + ImageKey);
    end;
  except
    on E: Exception do
    begin
      LogMessage(Format('从数据库加载图像失败: %s - %s', [ImageKey, E.Message]));
      SetLength(Result, 0);
    end;
  end;
end;

function TFrameAboutMe.LoadImageAndText(const ImageKey: string; out ImageData: TBytes; out AddressText: string): Boolean;
begin
  SetLength(ImageData, 0);
  AddressText := '';
  Result := False;

  try
    // 检查数据库是否可用
    if not Assigned(FDatabase) then
    begin
      LogMessage('数据库未初始化，跳过: ' + ImageKey);
      Exit;
    end;

    // 从数据库加载图像和文本
    Result := FDatabase.LoadImageAndText(ImageKey, ImageData, AddressText);
    if Result then
    begin
      LogMessage(Format('图像和文本加载成功: %s (%d 字节, 文本: %s)', [ImageKey, Length(ImageData), AddressText]));
    end
    else
    begin
      LogMessage('数据库中未找到图像和文本: ' + ImageKey);
    end;
  except
    on E: Exception do
    begin
      LogMessage(Format('加载图像和文本失败: %s - %s', [ImageKey, E.Message]));
      SetLength(ImageData, 0);
      AddressText := '';
      Result := False;
    end;
  end;
end;

