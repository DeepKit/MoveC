// 源目录右键菜单 - 删除目录
procedure TfrmMain.MenuItemDeleteDirClick(Sender: TObject);
var
  CurrentDir, SelectedDir, DirPath: string;
  ConfirmMsg: string;
  DirName: string;
begin
  try
    if Assigned(DirListBoxSource) then
    begin
      // 获取当前目录和选中的子目录
      CurrentDir := DirListBoxSource.Directory;

      // 检查是否有选中的项目
      if DirListBoxSource.ItemIndex >= 0 then
      begin
        // 获取选中的目录名
        DirName := DirListBoxSource.Items[DirListBoxSource.ItemIndex];

        // 构建完整路径
        if DirName = '..' then
        begin
          AddColoredStatusMessage('❌ 无法删除上级目录', clRed);
          Exit;
        end;

        DirPath := IncludeTrailingPathDelimiter(CurrentDir) + DirName;
      end
      else
      begin
        // 如果没有选中项，则删除当前目录（但这很危险，所以给出警告）
        AddColoredStatusMessage('❌ 请先选择要删除的子目录', clRed);
        Exit;
      end;

      if not DirectoryExists(DirPath) then
      begin
        AddColoredStatusMessage('❌ 目录不存在: ' + DirPath, clRed);
        Exit;
      end;

      // 检查是否是根目录
      if IsRootOrUserRootDirectory(DirPath) then
      begin
        AddColoredStatusMessage('❌ 禁止删除系统关键目录: ' + DirPath, clRed);
        Exit;
      end;

      ConfirmMsg := Format('确定要删除目录及其所有内容吗？%s%s%s%s警告：此操作将删除目录中的所有文件和子目录，不可恢复！',
