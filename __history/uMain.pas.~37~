// 源目录列表自绘事件
procedure TfrmMain.DirListBoxSourceDrawItem(Control: TWinControl; Index: Integer; Rect: TRect; State: TOwnerDrawState);
var
  DirListBox: TDirectoryListBox;
  ItemText: string;
  ItemPath: string;
  CurrentDir: string;
begin
  try
    DirListBox := Control as TDirectoryListBox;

    if (Index >= 0) and (Index < DirListBox.Items.Count) then
    begin
      ItemText := DirListBox.Items[Index];
      CurrentDir := DirListBox.Directory;

      // 清除背景
      DirListBox.Canvas.FillRect(Rect);

      // 检查是否为符号链接并设置颜色
      if ItemText <> '..' then
      begin
        ItemPath := IncludeTrailingPathDelimiter(CurrentDir) + ItemText;
        if IsSymbolicLink(ItemPath) then
        begin
          // 符号链接用蓝色背景
          DirListBox.Canvas.Brush.Color := RGB(240, 248, 255);
          DirListBox.Canvas.FillRect(Rect);
          DirListBox.Canvas.Font.Color := clBlue;
        end
        else
        begin
          // 普通目录用默认颜色
          DirListBox.Canvas.Font.Color := clWindowText;
        end;
      end
      else
      begin
        // 上级目录(..)用默认颜色
        DirListBox.Canvas.Font.Color := clWindowText;
      end;

      // 选中状态的特殊处理
      if odSelected in State then
      begin
        DirListBox.Canvas.Brush.Color := clHighlight;
        DirListBox.Canvas.FillRect(Rect);
        DirListBox.Canvas.Font.Color := clHighlightText;
      end;

      // 绘制文本（保留2像素边距）
      DirListBox.Canvas.TextOut(Rect.Left + 2, Rect.Top + 1, ItemText);

      // 绘制焦点框
      if odFocused in State then
        DirListBox.Canvas.DrawFocusRect(Rect);
    end;

  except
    // 出错时使用默认绘制
    with (Control as TDirectoryListBox) do
    begin
      Canvas.FillRect(Rect);
      Canvas.TextOut(Rect.Left + 2, Rect.Top + 1, Items[Index]);
    end;
  end;
end;

