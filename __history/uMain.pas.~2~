begin
  if (FSourcePath <> '') and TDirectory.Exists(FSourcePath) then
  begin
    ShellExecute(Handle, 'open', PChar(FSourcePath), nil, nil, SW_SHOWNORMAL);
    UpdateStatus('已打开源目录: ' + FSourcePath);
  end;
end;

