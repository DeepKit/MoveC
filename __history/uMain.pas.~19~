unit uMain;

interface

uses
  Winapi.Windows, Winapi.Messages, System.SysUtils, System.Variants,
  System.Classes, Vcl.Graphics,
  Vcl.Controls, Vcl.Forms, Vcl.Dialogs, Vcl.StdCtrls, Vcl.Mask, Vcl.ExtCtrls,
  Vcl.FileCtrl, Vcl.ComCtrls, System.IOUtils, ShellApi;

type
  TfrmMain = class(TForm)
    Panel1: TPanel;
    Panel2: TPanel;
    Panel3: TPanel;
    Panel4: TPanel;
    DirListBoxSource: TDirectoryListBox;
    FileListBoxSource: TFileListBox;
    Splitter1: TSplitter;
    Splitter2: TSplitter;
    DirListBoxTarget: TDirectoryListBox;
    FileListBoxTarget: TFileListBox;
    edtSource: TLabeledEdit;
    edtTarget: TLabeledEdit;
    FileOpenDialog: TFileOpenDialog;
    btnDirSource: TButton;
    btnDirTarget: TButton;
    btnMove: TButton;
    btnClose: TButton;
    btnLink: TButton;
    ProgressBar: TProgressBar;
    Button1: TButton;
    procedure btnDirSourceClick(Sender: TObject);
    procedure btnDirTargetClick(Sender: TObject);
    procedure edtSourceChange(Sender: TObject);
    procedure edtTargetChange(Sender: TObject);
    procedure btnMoveClick(Sender: TObject);
    procedure btnCloseClick(Sender: TObject);
    procedure FormCreate(Sender: TObject);
    procedure btnLinkClick(Sender: TObject);
    procedure Button1Click(Sender: TObject);
  private
    { Private declarations }
    procedure UpdateUI_Show;
    procedure UpdateUI_Hide;
    procedure CopyFilesOverwrite(SourcePath, DestPath: string);
  public
    { Public declarations }
  end;

var
  frmMain: TfrmMain;

implementation

{$R *.dfm}

procedure TfrmMain.UpdateUI_Show;
begin
  // 恢复原状
  btnDirSource.Enabled := True;
  btnDirTarget.Enabled := True;
  btnMove.Enabled := True;
  btnLink.Enabled := True;
  btnClose.Enabled := True;
  frmMain.Cursor := crDefault;
end;

procedure TfrmMain.UpdateUI_Hide;
begin
  // 让一些按钮不可用，让鼠标显示为不可操作
  btnDirSource.Enabled := False;
  btnDirTarget.Enabled := False;
  btnMove.Enabled := False;
  btnLink.Enabled := False;
  btnClose.Enabled := False;
  frmMain.Cursor := crHourGlass;;
end;

procedure TfrmMain.btnCloseClick(Sender: TObject);
begin
  Self.Close;
end;

procedure TfrmMain.btnDirSourceClick(Sender: TObject);
begin
  if FileOpenDialog.Execute then
  begin
    edtSource.Text := FileOpenDialog.FileName;
    DirListBoxSource.Directory := ExtractFilePath(edtSource.Text);
  end;
end;

procedure TfrmMain.btnDirTargetClick(Sender: TObject);
begin
  if FileOpenDialog.Execute then
  begin
    edtTarget.Text := FileOpenDialog.FileName;
    DirListBoxTarget.Directory := ExtractFilePath(edtTarget.Text);
  end;
end;

procedure TfrmMain.CopyFilesOverwrite(SourcePath, DestPath: string);
var
  SearchRec: TSearchRec;
  FullSourcePath, FullDestPath: string;
begin
  // 遍历源目录中的所有文件和子目录
  if FindFirst(SourcePath + '\*', faAnyFile, SearchRec) = 0 then
  begin
    try
      repeat
        FullSourcePath := SourcePath + '\' + SearchRec.Name;
        FullDestPath := DestPath + '\' + SearchRec.Name;

        if (SearchRec.Attr and faDirectory) = faDirectory then
        begin
          // 如果是目录，递归调用
          if SearchRec.Name <> '.' then
          begin
            if not DirectoryExists(FullDestPath) then
              CreateDir(FullDestPath);

            CopyFilesOverwrite(FullSourcePath, FullDestPath);
          end;
        end
        else
        begin
          // 如果是文件，直接拷贝
          if not FileExists(FullDestPath) or
            (FileGetAttr(FullDestPath) and faReadOnly <> faReadOnly) then
          begin
            TFile.Copy(FullSourcePath, FullDestPath, True);
          end;
        end;
      until FindNext(SearchRec) <> 0;
    finally
      FindClose(SearchRec);
    end;
  end;
end;

procedure TfrmMain.btnMoveClick(Sender: TObject);
var
  i: Integer;
  sourceDir, targetDir: string;
  DestPath: string;
begin
  UpdateUI_Hide; // 让一些按钮不可用，让鼠标显示为不可操作

  try
    sourceDir := DirListBoxSource.Directory;
    targetDir := DirListBoxTarget.Directory;
    for i := 0 to FileListBoxSource.Items.Count - 1 do
    begin
      DestPath := targetDir + '\' + FileListBoxSource.Items[i];
      CopyFilesOverwrite(sourceDir, DestPath);
      DirListBoxSource.Update;
      DirListBoxTarget.Update;
      ProgressBar.Position := i + 1;
    end;
  finally
    UpdateUI_Show;
    ShowMessage('目录移动完成，部分目录未能移动。');
  end;
end;

procedure TfrmMain.Button1Click(Sender: TObject);
var
  TargetPath, SourcePath, Command, BatFileName: string;
  FileHandle: TextFile; // 声明文件句柄变量
begin
  // 设置目标路径
  TargetPath := edtTarget.Text + '\' + DirListBoxTarget.Items
    [DirListBoxTarget.ItemIndex];

  // 设置源路径
  SourcePath := 'C:' + Copy(TargetPath, 3, MaxInt);

  // 构建命令
  Command := 'mklink /D ' + '"' + SourcePath + '"' + '  ' + '"' +
    TargetPath + '"';

  // 构建批处理文件名
  BatFileName := 'D:\CreateSymbolicLink.bat';

  // 打开文件并写入命令

  try
    Rewrite(FileHandle);
    Writeln(FileHandle, '@echo off');
    Writeln(FileHandle, Command);
  finally
    CloseFile(FileHandle); // 确保文件句柄被关闭
  end;

  // 显示批处理文件路径，让用户知道在哪里可以找到它
  ShowMessage('The batch file has been created at: ' + GetCurrentDir +
    '\CreateSymbolicLink.bat');
end;

procedure TfrmMain.btnLinkClick(Sender: TObject);
var
  SourcePath, TargetPath, Command, BatFileName: string;
  i: Integer;
  FileHandle: TextFile; // 声明文件句柄变量
begin
  UpdateUI_Hide; // 让一些按钮不可用，让鼠标显示为不可操作
  ProgressBar.Max := DirListBoxTarget.Items.Count;
  try
    // 构建批处理文件名
    BatFileName := 'CreateSymbolicLink.bat';
    AssignFile(FileHandle, BatFileName);
    try
      Rewrite(FileHandle);
      Writeln(FileHandle, '@echo off');
      for i := 0 to DirListBoxTarget.Items.Count - 1 do
      begin
        TargetPath := edtTarget.Text + '\' + DirListBoxTarget.Items[i];
        // 设置源路径
        SourcePath := 'C:' + Copy(TargetPath, 3, MaxInt);

        // 构建命令

        try
          if not DirectoryExists(SourcePath) then
          begin
            // 生成可以插入bat文件的代码
            Command := 'mklink /D ' + '"' + SourcePath + '"' + '  ' + '"' +
              TargetPath + '"';
            Writeln(FileHandle, Command);
          end
          else
          begin
            // Copy files from D: to C:
            if DirectoryExists(SourcePath) then
              CopyFilesOverwrite(SourcePath, TargetPath);
          end;
        except
          on E: Exception do
          begin
            if Pos('拒绝访问', E.Message) > 0 then
            begin
              // Skip this directory if access is denied
              Continue;
            end
            else
            begin
              // Handle other exceptions as needed
              ShowMessage('An error occurred: ' + E.Message);
              Break;
            end;
          end;
        end;

        ProgressBar.Position := i + 1;
        Application.ProcessMessages; // Allow UI updates
      end;
    finally
      CloseFile(FileHandle); // 确保文件句柄被关闭
    end;
  finally
    UpdateUI_Show;
  end;
    ShowMessage('BAT命令文件已经生成，它在D盘根目录下，请用管理员权限执行它，文件名为: CreateSymbolicLink.bat');
end;

procedure TfrmMain.edtTargetChange(Sender: TObject);
begin
  DirListBoxTarget.Directory := edtTarget.Text;
end;

procedure TfrmMain.edtSourceChange(Sender: TObject);
begin
  DirListBoxSource.Directory := edtSource.Text;
end;

procedure TfrmMain.FormCreate(Sender: TObject);
begin
  edtSourceChange(Sender);
  edtTargetChange(Sender);
end;

end.
