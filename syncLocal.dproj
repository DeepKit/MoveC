<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
    <PropertyGroup>
        <ProjectGuid>{7A2D4C3B-8E1F-4A9C-B5D2-E6F7A8B9C0D1}</ProjectGuid>
        <ProjectVersion>20.3</ProjectVersion>
        <FrameworkType>VCL</FrameworkType>
        <Base>True</Base>
        <Config Condition="'$(Config)'==''">Debug</Config>
        <Platform Condition="'$(Platform)'==''">Win64</Platform>
        <ProjectName Condition="'$(ProjectName)''==''">syncLocal</ProjectName>
        <TargetedPlatforms>3</TargetedPlatforms>
        <AppType>Application</AppType>
        <MainSource>syncLocal.dpr</MainSource>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Config)'=='Base' or '$(Base)'!=''">
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Config)'=='Debug' or '$(Cfg_1)'!=''">
        <Cfg_1>true</Cfg_1>
        <CfgParent>Base</CfgParent>
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Config)'=='Release' or '$(Cfg_2)'!=''">
        <Cfg_2>true</Cfg_2>
        <CfgParent>Base</CfgParent>
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Base)'!=''">
        <DCC_DcuOutput>.\$(Platform)\$(Config)</DCC_DcuOutput>
        <DCC_ExeOutput>.\$(Platform)\$(Config)</DCC_ExeOutput>
        <DCC_E>false</DCC_E>
        <DCC_N>false</DCC_N>
        <DCC_S>false</DCC_S>
        <DCC_F>false</DCC_F>
        <DCC_K>false</DCC_K>
        <DCC_Namespace>System;Xml;Data;Datasnap;Web;Soap;Vcl;Vcl.Imaging;Vcl.Touch;Vcl.Samples;Vcl.Shell;$(DCC_Namespace)</DCC_Namespace>
        <SanitizedProjectName>syncLocal</SanitizedProjectName>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Cfg_1)'!=''">
        <DCC_Define>DEBUG;$(DCC_Define)</DCC_Define>
        <DCC_DebugDCUs>true</DCC_DebugDCUs>
        <DCC_Optimize>false</DCC_Optimize>
        <DCC_GenerateStackFrames>true</DCC_GenerateStackFrames>
        <DCC_DebugInfoInExe>true</DCC_DebugInfoInExe>
        <DCC_RemoteDebug>true</DCC_RemoteDebug>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Cfg_2)'!=''">
        <DCC_LocalDebugSymbols>false</DCC_LocalDebugSymbols>
        <DCC_Define>RELEASE;$(DCC_Define)</DCC_Define>
        <DCC_SymbolReferenceInfo>0</DCC_SymbolReferenceInfo>
        <DCC_DebugInformation>0</DCC_DebugInformation>
    </PropertyGroup>
    <ItemGroup>
        <DelphiCompile Include="$(MainSource)">
            <MainSource>MainSource</MainSource>
        </DelphiCompile>
        <DCCReference Include="uSyncLocalMain.pas">
            <Form>frmSyncLocalMain</Form>
            <FormType>dfm</FormType>
        </DCCReference>
        <DCCReference Include="uSplash.pas">
            <Form>frmSplash</Form>
        </DCCReference>
        <DCCReference Include="uIconManager.pas"/>
        <DCCReference Include="uTrayIcon.pas"/>
        <DCCReference Include="uEnhancedTrayIcon.pas"/>
        <DCCReference Include="uSyncDatabase.pas"/>
        <DCCReference Include="uSyncEngine.pas"/>
        <DCCReference Include="uFileSystemWatcher.pas"/>
        <DCCReference Include="uNativeFileWatcher.pas"/>
        <DCCReference Include="uRealtimeSyncManager.pas"/>
        <DCCReference Include="uSyncExecutor.pas"/>
        <DCCReference Include="uSyncExecutorSimple.pas"/>
        <DCCReference Include="uFileSyncComparer.pas"/>
        <DCCReference Include="uFileSyncComparerSimple.pas"/>
        <DCCReference Include="uConflictResolver.pas"/>
        <DCCReference Include="uSyncSettingsBasic.pas">
            <Form>frmSyncSettingsBasic</Form>
            <FormType>dfm</FormType>
        </DCCReference>
        <DCCReference Include="uSyncTaskEdit.pas">
            <Form>frmSyncTaskEdit</Form>
            <FormType>dfm</FormType>
        </DCCReference>
        <DCCReference Include="uSyncHistory.pas">
            <Form>frmSyncHistory</Form>
            <FormType>dfm</FormType>
        </DCCReference>
        <DCCReference Include="uLogger.pas"/>
        <DCCReference Include="uNetworkPathManager.pas"/>
        <DCCReference Include="uNetworkConnectionMonitor.pas"/>
        <DCCReference Include="uSyncPresets.pas"/>
        <DCCReference Include="uDatabaseMigration.pas"/>
        <DCCReference Include="uDatabaseConfig.pas"/>
        <DCCReference Include="uSyncLocalTrayIcon.pas"/>
        <BuildConfiguration Include="Base">
            <Key>Base</Key>
        </BuildConfiguration>
        <BuildConfiguration Include="Debug">
            <Key>Cfg_1</Key>
            <CfgParent>Base</CfgParent>
        </BuildConfiguration>
        <BuildConfiguration Include="Release">
            <Key>Cfg_2</Key>
            <CfgParent>Base</CfgParent>
        </BuildConfiguration>
    </ItemGroup>
    <ProjectExtensions>
        <Borland.Personality>Delphi.Personality.12</Borland.Personality>
        <Borland.ProjectType>Application</Borland.ProjectType>
        <BorlandProject>
            <Delphi.Personality>
                <Source>
                    <Source Name="MainSource">syncLocal.dpr</Source>
                </Source>
            </Delphi.Personality>
        </BorlandProject>
    </ProjectExtensions>
</Project>
